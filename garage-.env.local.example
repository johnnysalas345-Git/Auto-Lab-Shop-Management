# Supabase Configuration
# Get these from: https://app.supabase.com/project/gvsbbpuuoxluqaiovtvx/settings/api

VITE_SUPABASE_URL=https://gvsbbpuuoxluqaiovtvx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Instructions:
# 1. Copy this file and rename to .env.local
# 2. Go to Supabase dashboard → Settings → API
# 3. Copy "Project URL" and paste after VITE_SUPABASE_URL=
# 4. Copy "anon public" key and paste after VITE_SUPABASE_ANON_KEY=
# 5. Save .env.local
# 6. DO NOT commit .env.local to GitHub (it's in .gitignore)
